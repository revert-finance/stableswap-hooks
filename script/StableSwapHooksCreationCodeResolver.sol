pragma solidity 0.8.30;

import {Script, console2} from "forge-std/Script.sol";

import {StableSwapHooks} from "src/StableSwapHooks.sol";
import {StableSwapHooksFactory} from "src/factories/StableSwapHooksFactory.sol";

/// @notice Resolves the StableSwapHooks creation code expected by a target factory.
/// @dev Existing Base deployments may pin an older StableSwapHooks creation-code hash.
abstract contract StableSwapHooksCreationCodeResolver is Script {
    error CreationCodeHashMismatch(bytes32 localHash, bytes32 expectedHash);

    function _legacyCreationCode() private pure returns (bytes memory) {
        return hex"";
    }

    function _resolveCreationCode(StableSwapHooksFactory _factory) internal view returns (bytes memory creationCode) {
        bytes32 expectedHash = _factory.creationCodeHash();

        creationCode = type(StableSwapHooks).creationCode;

        if (keccak256(creationCode) == expectedHash) {
            return creationCode;
        }

        creationCode = _legacyCreationCode();

        bytes32 localHash = keccak256(creationCode);

        if (localHash != expectedHash) {
            revert CreationCodeHashMismatch(localHash, expectedHash);
        }

        console2.log("Using hardcoded legacy creation code.");
    }
}
