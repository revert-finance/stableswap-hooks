pragma solidity 0.8.30;

import {Test} from "forge-std/Test.sol";

import {IPoolManager} from "@uniswap/v4-core/src/interfaces/IPoolManager.sol";
import {Currency} from "@uniswap/v4-core/src/types/Currency.sol";

import {IAllowanceTransfer} from "permit2/src/interfaces/IAllowanceTransfer.sol";

import {IUniversalRouter} from "test/testUtils/external/interfaces/IUniversalRouter.sol";
import {IFiatTokenV2} from "test/testUtils/external/interfaces/IFiatTokenV2.sol";

abstract contract ExternalContractsDeployer is Test {
    address internal constant POOL_MANAGER_ADDRESS = 0x000000000004444c5dc75cB358380D2e3dE08A90;
    address internal constant PERMIT2_ADDRESS = 0x000000000022D473030F116dDEE9F6B43aC78BA3;
    address internal constant UNIVERSAL_ROUTER_ADDRESS = 0x66a9893cC07D91D95644AEDD05D03f95e1dBA8Af;
    address internal constant DAI_ADDRESS = 0x6B175474E89094C44Da98b954EedeAC495271d0F;
    address internal constant USDC_ADDRESS = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48;
    address internal constant USDT_ADDRESS = 0xdAC17F958D2ee523a2206206994597C13D831ec7;

    IPoolManager internal poolManager;
    IAllowanceTransfer internal permit2;
    IUniversalRouter internal universalRouter;
    Currency internal currency0;
    Currency internal currency1;
    Currency internal currency2;

    error InvalidChainId(uint256 _chainId);

    function setUp() public virtual {
        _deployPoolManager();
        _deployPermit2();
        _deployUniversalRouter();
        _deployCurrency0();
        _deployCurrency1();
        _deployCurrency2();
    }

    function _deployPoolManager() private {
        if (block.chainid == 31337) {
            bytes memory initcode =
                hex"";
            bytes memory args = abi.encode(makeAddr("poolManagerOwner"));
            bytes memory initcodeWithArgs = abi.encodePacked(initcode, args);
            // Cannot etch because of some delegate call prevention the pool manager has
            poolManager = IPoolManager(_deploy(initcodeWithArgs));
        } else if (block.chainid == 1) {
            poolManager = IPoolManager(POOL_MANAGER_ADDRESS);
        } else {
            revert InvalidChainId(block.chainid);
        }

        vm.label(address(poolManager), "PoolManager");
    }

    function _deployPermit2() private {
        if (block.chainid == 31337) {
            bytes memory initcode =
                hex"";
            permit2 = IAllowanceTransfer(_deployAndEtch(initcode, PERMIT2_ADDRESS));
        } else if (block.chainid == 1) {
            permit2 = IAllowanceTransfer(PERMIT2_ADDRESS);
        } else {
            revert InvalidChainId(block.chainid);
        }

        vm.label(address(permit2), "Permit2");
    }

    function _deployUniversalRouter() private {
        if (block.chainid == 31337) {
            bytes memory initcode =
                hex"";
            bytes memory args = abi.encode(
                address(permit2),
                makeAddr("weth9"),
                makeAddr("v2Factory"),
                makeAddr("v3Factory"),
                keccak256("pairInitCodeHash"),
                keccak256("poolInitCodeHash"),
                address(poolManager),
                makeAddr("v3NFTPositionManager"),
                makeAddr("v4PositionManager")
            );
            bytes memory initcodeWithArgs = abi.encodePacked(initcode, args);
            universalRouter = IUniversalRouter(_deployAndEtch(initcodeWithArgs, UNIVERSAL_ROUTER_ADDRESS));
        } else if (block.chainid == 1) {
            universalRouter = IUniversalRouter(UNIVERSAL_ROUTER_ADDRESS);
        } else {
            revert InvalidChainId(block.chainid);
        }

        vm.label(address(universalRouter), "UniversalRouter");
    }

    function _deployCurrency0() private {
        // DAI
        if (block.chainid == 31337) {
            bytes memory initcode =
                hex"";
            bytes memory args = abi.encode(block.chainid);
            bytes memory initcodeWithArgs = abi.encodePacked(initcode, args);
            currency0 = Currency.wrap(_deployAndEtch(initcodeWithArgs, DAI_ADDRESS));
        } else if (block.chainid == 1) {
            currency0 = Currency.wrap(DAI_ADDRESS);
        } else {
            revert InvalidChainId(block.chainid);
        }
    }

    function _deployCurrency1() private {
        // USDC
        if (block.chainid == 31337) {
            bytes memory initcode =
                hex"";
            _deployAndEtch(initcode, USDC_ADDRESS);
            currency1 = Currency.wrap(USDC_ADDRESS);
            IFiatTokenV2 usdc = IFiatTokenV2(USDC_ADDRESS);
            usdc.initialize("USD Coin", "USDC", "USD", 6, address(this), address(this), address(this), address(this));
            usdc.configureMinter(address(this), type(uint256).max);
            usdc.mint(address(this), 100_000e6);
        } else if (block.chainid == 1) {
            currency1 = Currency.wrap(USDC_ADDRESS);
        } else {
            revert InvalidChainId(block.chainid);
        }
    }

    function _deployCurrency2() private {
        // USDT
        if (block.chainid == 31337) {
            bytes memory initcode =
                hex"";
            bytes memory args = abi.encode(100_000_000_000, "Tether USD", "USDT", 6);
            bytes memory initcodeWithArgs = abi.encodePacked(initcode, args);
            currency2 = Currency.wrap(_deployAndEtch(initcodeWithArgs, USDT_ADDRESS));
        } else if (block.chainid == 1) {
            currency2 = Currency.wrap(USDT_ADDRESS);
        } else {
            revert InvalidChainId(block.chainid);
        }
    }

    function _deploy(bytes memory _initcode) private returns (address) {
        address deployed;
        assembly ("memory-safe") {
            deployed := create2(0, add(_initcode, 32), mload(_initcode), hex"00")
            if iszero(deployed) {
                let ptr := mload(0x40)
                let errorSize := returndatasize()
                returndatacopy(ptr, 0, errorSize)
                revert(ptr, errorSize)
            }
        }
        return deployed;
    }

    function _deployAndEtch(bytes memory _initcode, address _targetAddress) private returns (address) {
        address deployed = _deploy(_initcode);
        vm.etch(_targetAddress, deployed.code);
        vm.copyStorage(deployed, _targetAddress);
        return _targetAddress;
    }
}
