# StableSwap Deployment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# RPC URLS (Chain-specific)
# Format: <CHAIN_NAME>_RPC_URL
# =============================================================================

# Mainnets
ETHEREUM_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
BASE_RPC_URL=
POLYGON_RPC_URL=
BSC_RPC_URL=
AVALANCHE_RPC_URL=
CELO_RPC_URL=

# Testnets
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
OPTIMISM_SEPOLIA_RPC_URL=

# Local (defaults to http://127.0.0.1:8545 if not set)
ANVIL_RPC_URL=http://127.0.0.1:8545

# =============================================================================
# FACTORY DEPLOYMENT CONFIGURATION
# =============================================================================

# PoolManager address (chain-specific)
# Leave empty to use chain default from ChainConfig.sol
POOL_MANAGER=

# Factory owner address (has admin controls over fees and parameters)
# IMPORTANT: Consider using a multisig for production deployments
FACTORY_OWNER=

# Protocol fee collector address (receives protocol fees from all hooks)
PROTOCOL_FEE_COLLECTOR=

# Hook fee collector address (receives hook fees from all hooks)
HOOK_FEE_COLLECTOR=

# =============================================================================
# HOOK DEPLOYMENT CONFIGURATION
# =============================================================================

# Address of deployed StableSwapHooksFactory
FACTORY_ADDRESS=

# Comma-separated list of currency addresses
# MUST be sorted in ascending numerical order
# Use CLI tool to validate: cd script/tools && npm run cli validate-currencies <addresses>
# Example: 0x6B175474E89094C44Da98b954EedeAC495271d0F,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
CURRENCIES=

# Comma-separated list of rate oracle addresses
# Use 0x0000000000000000000000000000000000000000 for currencies with static 1:1 rate
# Must have same length as CURRENCIES
# Example: 0x0000000000000000000000000000000000000000,0x0000000000000000000000000000000000000000
RATE_ORACLES=

# Comma-separated list of rate oracle function selectors
# Use 0x00000000 for currencies without oracles
# Must have same length as CURRENCIES
# Example: 0x00000000,0x00000000
RATE_ORACLE_SELECTORS=

# LP fee percentage (scaled by 1,000,000)
# Examples:
#   100 = 0.01%
#   300 = 0.03%
#   500 = 0.05%
#   1000 = 0.1%
LP_FEE_PERCENTAGE=300

# Initial amplification coefficient
# Higher values = more stable pricing around equilibrium
# Examples:
#   50 = Lower amplification (less correlated assets)
#   100 = Medium amplification
#   2000 = High amplification (very stable assets like USDC/USDT)
BASE_AMP=100

# =============================================================================
# POOL INITIALIZATION (Optional)
# =============================================================================

# Set to true to initialize all pairwise pools after hook deployment
INITIALIZE_POOLS=false

# Initial sqrt price (only used if INITIALIZE_POOLS=true)
# Default: 79228162514264337593543950336 (equivalent to 1<<96, represents 1:1 price)
SQRT_PRICE_X96=79228162514264337593543950336

# =============================================================================
# EXAMPLES
# =============================================================================

# Example 1: USDC/USDT/DAI Stablecoin Pool
# CURRENCIES=0x6B175474E89094C44Da98b954EedeAC495271d0F,0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0xdAC17F958D2ee523a2206206994597C13D831ec7
# RATE_ORACLES=0x0000000000000000000000000000000000000000,0x0000000000000000000000000000000000000000,0x0000000000000000000000000000000000000000
# RATE_ORACLE_SELECTORS=0x00000000,0x00000000,0x00000000
# LP_FEE_PERCENTAGE=100
# BASE_AMP=2000

# Example 2: WETH/stETH/wstETH LST Pool (with rate oracle for wstETH)
# CURRENCIES=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2,0xae7ab96520DE3A18E5e111B5EaAb095312D7fE84,0x7f39C581F595B53c5cb19bD0b3f8dA6c935E2Ca0
# RATE_ORACLES=0x0000000000000000000000000000000000000000,0x0000000000000000000000000000000000000000,0xYourWstETHOracleAddress
# RATE_ORACLE_SELECTORS=0x00000000,0x00000000,0xYourOracleSelector
# LP_FEE_PERCENTAGE=400
# BASE_AMP=50
